rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ⚠️ TROQUE pelo seu e-mail de dono do app (o mesmo do ADMIN_EMAIL no index.html)
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == "markos_bad@hotmail.com";
    }
    function logado() { return request.auth != null; }

    // ---------- USUÁRIOS ----------
    // Cada um lê/escreve apenas o próprio perfil. Admin lê todos.
    match /users/{uid} {
      allow read: if logado() && (request.auth.uid == uid || isAdmin());
      allow create: if logado() && request.auth.uid == uid;
      allow update: if logado() && request.auth.uid == uid;
      allow delete: if false;
    }

    // ---------- ENTREGAS ----------
    match /entregas/{id} {
      // qualquer usuário logado vê as entregas (necessário p/ mapa em tempo real)
      allow read: if logado();

      // só a própria loja cria, já com status "disponivel"
      allow create: if logado()
        && request.resource.data.lojaId == request.auth.uid
        && request.resource.data.status == "disponivel";

      // atualizações permitidas:
      // 1) a loja/solicitante dono (cancelar, avaliar entregador)
      // 2) o entregador designado (coletar, concluir, desistir, GPS, avaliar loja)
      // 3) um entregador aceitando uma entrega disponível (se designando)
      //    — nunca a própria entrega
      allow update: if logado() && (
        resource.data.lojaId == request.auth.uid
        || resource.data.entregadorId == request.auth.uid
        || (resource.data.status == "disponivel"
            && request.resource.data.entregadorId == request.auth.uid
            && request.resource.data.entregadorId != resource.data.lojaId
            && request.resource.data.status == "aceita")
      );

      allow delete: if false;
    }

    // ---------- SAQUES ----------
    match /saques/{id} {
      // entregador cria o próprio pedido de saque
      allow create: if logado()
        && request.resource.data.entregadorId == request.auth.uid
        && request.resource.data.status == "pendente";
      // entregador vê os próprios; admin vê e atualiza todos (marcar pago)
      allow read: if logado() && (resource.data.entregadorId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
